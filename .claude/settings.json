{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "SessionStart": [
      {
        "command": ".claude/hooks/session-start.sh",
        "timeout": 5000
      }
    ],
    "Stop": [
      {
        "command": ".claude/hooks/ship-loop.sh",
        "timeout": 10000
      }
    ],
    "PostToolUse": [
      {
        "command": ".claude/hooks/context-monitor.sh",
        "timeout": 5000
      }
    ]
  }
}
